{
  "neodev": {
    "library": {
      "enabled": true,
      "plugins": true
    }
  },
  "neoconf": {
    "plugins": {
      "lua_ls": {
        "enabled": true
      }
    }
  },
  "lspconfig": {
    "lua_ls": {
      "Lua.format.enable": false
    },
    "nixd": {
      "nixd": {
        "options": {
          "nixos-config": {
            "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.argo.options"
          },
          "home-config": {
            "expr": "(builtins.getFlake (builtins.toString ./.)).nixosConfigurations.argo.options.home-manager.users.type.getSubOptions []"
          }
        },
        "nixpkgs": {
          "expr": "(builtins.getFlake (builtins.toString ./.)).inputs.nixpkgs.legacyPackages.x86_64-linux"
        }
      }
    }
  }
}
